            let imageUrl = "https://io.narrative.io/?companyId=2440&id=first_party%3A92b258a6-bda9-4a67-8642-ad491d8f8dad&id=site_name%3Asourceforge.net&id=url%3A%2Fprojects%2Fdigicamcontrol%2Ffiles%2F&id=pagetitle%3AdigiCamControl+-++Browse+Files+at+SourceForge.net&id=vertical%3AOpen+Source+Software&id=product%3AdigiCamControl&id=topics%3AImage+Viewers%2CDigital+Camera&id=programming_language%3AC%23";
            imageUrl = imageUrl.replace(encodeURIComponent("$PAGE_TITLE"), document.title);  

            imageUrl = URL.parse(imageUrl);
            let hem = bizx.uids.getHem();
            if (hem) {
                imageUrl.searchParams.append('id', 'hem:' + hem);
            }
            imageUrl.searchParams.append('rand', current_time);

            var image = new Image();
            image.src = imageUrl.toString();
            image.style.display = "none";
            image.style.height = 0;
            image.style.width = 0;
            document.body.appendChild(image);
        });
    });
</script>
        

        
            
